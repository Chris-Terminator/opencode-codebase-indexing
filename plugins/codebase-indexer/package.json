{
  "name": "opencode-codebase-indexer",
  "version": "0.1.6",
  "description": "Qdrant-backed semantic code search and automatic indexing for OpenCode.",
  "type": "module",
  "main": "./dist/plugin.js",
  "exports": {
    ".": "./dist/plugin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.kilocode",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json --noEmit && node scripts/build-plugin.mjs && node scripts/copy-tree-sitter-wasms.mjs",
    "test": "bun test",
    "check": "npm run build && npm test",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.4",
    "@qdrant/js-client-rest": "1.17.0",
    "async-mutex": "0.5.0",
    "chokidar": "4.0.3",
    "glob": "13.0.6",
    "ignore": "7.0.5",
    "minimatch": "10.2.5",
    "openai": "6.27.0",
    "p-limit": "7.3.0",
    "tree-sitter-wasms": "0.1.13",
    "uuid": "14.0.0",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "esbuild": "0.25.12",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=22",
    "opencode": ">=1.17.4"
  },
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "semantic-search",
    "code-indexing",
    "qdrant"
  ]
}
